{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Vault application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        },
        "balance": {
          "type": "number",
          "description": "The user's current balance including realized interest."
        },
        "costBasis": {
          "type": "number",
          "description": "The user's total deposits minus withdrawals."
        },
        "lastUpdate": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the balance was updated."
        }
      },
      "required": ["uid", "email", "name", "role", "balance", "costBasis", "lastUpdate"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A deposit or withdrawal transaction.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The ID of the user who made the transaction."
        },
        "type": {
          "type": "string",
          "enum": ["deposit", "withdrawal"],
          "description": "The type of transaction."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the transaction."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time of the transaction."
        }
      },
      "required": ["uid", "type", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and balances."
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores all user transactions."
    }
  }
}
